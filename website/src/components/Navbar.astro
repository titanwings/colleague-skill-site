---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="absolute inset-0 bg-surface-900/80 backdrop-blur-md border-b border-surface-800/50 opacity-0 transition-opacity duration-300" id="navbar-bg"></div>

  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`${base}/`} class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-brand-500/20 border border-brand-500/40 flex items-center justify-center group-hover:bg-brand-500/30 transition-colors">
          <span class="text-brand-400 font-mono font-bold text-base">.</span>
        </div>
        <span class="font-bold text-white text-base hidden sm:block font-mono">
          <span class="text-brand-400">dot</span>-skill
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href={`${base}/`}
          class:list={[
            'px-4 py-2 rounded-lg text-base font-medium transition-colors',
            currentPath === `${base}/` || currentPath === `${base}`
              ? 'text-brand-400 bg-brand-500/10'
              : 'text-surface-300 hover:text-white hover:bg-surface-800'
          ]}
        >
          <span class="lang-zh">首页</span>
          <span class="lang-en">Home</span>
        </a>
        <a
          href={`${base}/gallery/`}
          class:list={[
            'px-4 py-2 rounded-lg text-base font-medium transition-colors',
            currentPath.includes('/gallery')
              ? 'text-brand-400 bg-brand-500/10'
              : 'text-surface-300 hover:text-white hover:bg-surface-800'
          ]}
        >
          Skill Gallery
        </a>
        <a
          href="https://github.com/titanwings/colleague-skill"
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-lg text-base font-medium text-surface-300 hover:text-white hover:bg-surface-800 transition-colors flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <a
          href="https://discord.gg/aRjmJBdK"
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-lg text-base font-medium text-surface-300 hover:text-indigo-400 hover:bg-surface-800 transition-colors flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.036.055a19.904 19.904 0 0 0 5.993 3.03.077.077 0 0 0 .084-.028 13.99 13.99 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .036-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
          Discord
        </a>
      </div>

      <!-- CTA Buttons -->
      <div class="flex items-center gap-2">
        <!-- Language toggle -->
        <button
          id="lang-toggle"
          class="px-2.5 py-1.5 rounded-lg text-base font-mono font-bold border border-surface-700 hover:border-brand-500/50 text-surface-400 hover:text-brand-400 transition-all"
          title="Switch language / 切换语言"
          aria-label="Toggle language"
        >
          <span id="lang-label">EN</span>
        </button>
        <a
          href={`${base}/gallery/`}
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 text-base font-medium text-surface-300 hover:text-white border border-surface-700 hover:border-surface-600 rounded-lg transition-all hover:bg-surface-800"
        >
          Gallery
        </a>
        <a
          href="https://github.com/titanwings/colleague-skill"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-4 py-2 text-base font-semibold bg-brand-500 hover:bg-brand-400 text-surface-900 rounded-lg transition-all hover:shadow-glow-amber"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
          Star
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-surface-400 hover:text-white hover:bg-surface-800 transition-colors"
          aria-label="Toggle menu"
        >
          <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 space-y-1">
      <a href={`${base}/`} class="block px-4 py-2.5 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800 transition-colors">
        <span class="lang-zh">首页</span><span class="lang-en">Home</span>
      </a>
      <a href={`${base}/gallery/`} class="block px-4 py-2.5 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800 transition-colors">Skill Gallery</a>
      <a href="https://github.com/titanwings/colleague-skill" target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800 transition-colors">GitHub →</a>
      <a href="https://discord.gg/aRjmJBdK" target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 rounded-lg text-surface-300 hover:text-indigo-400 hover:bg-surface-800 transition-colors">Discord →</a>
    </div>
  </nav>
</header>

<script>
  // Language toggle
  const langToggle = document.getElementById('lang-toggle');
  const langLabel = document.getElementById('lang-label');
  const savedLang = localStorage.getItem('dotskill-lang') || 'zh';
  document.documentElement.setAttribute('data-lang', savedLang);
  if (langLabel) langLabel.textContent = savedLang === 'zh' ? 'EN' : '中';

  langToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-lang') || 'zh';
    const next = current === 'zh' ? 'en' : 'zh';
    document.documentElement.setAttribute('data-lang', next);
    localStorage.setItem('dotskill-lang', next);
    if (langLabel) langLabel.textContent = next === 'zh' ? 'EN' : '中';
  });

  const navbar = document.getElementById('navbar');
  const navbarBg = document.getElementById('navbar-bg');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbarBg?.classList.remove('opacity-0');
      navbarBg?.classList.add('opacity-100');
    } else {
      navbarBg?.classList.remove('opacity-100');
      navbarBg?.classList.add('opacity-0');
    }
  });

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    menuIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });
</script>
