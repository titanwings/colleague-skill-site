---
import type { SkillMeta } from '../types/skill';

interface Props {
  skill: SkillMeta;
  base: string;
}

const { skill, base } = Astro.props;

const NEW_WINDOW_DAYS = 14;
const isNew = (() => {
  if (!skill.created_at) return false;
  const created = new Date(skill.created_at);
  if (Number.isNaN(created.getTime())) return false;
  const ageMs = Date.now() - created.getTime();
  return ageMs >= 0 && ageMs <= NEW_WINDOW_DAYS * 24 * 60 * 60 * 1000;
})();

function formatStars(n: number): string {
  if (n < 1000) return String(n);
  if (n < 10000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return Math.round(n / 1000) + 'k';
}

const tagColors: Record<string, string> = {
  security: 'bg-red-500/10 text-red-400 border-red-500/20',
  backend: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  frontend: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  devops: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  data: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  design: 'bg-pink-500/10 text-pink-400 border-pink-500/20',
  product: 'bg-green-500/10 text-green-400 border-green-500/20',
  hr: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  management: 'bg-brand-500/10 text-brand-400 border-brand-500/20',
  other: 'bg-surface-700 text-surface-400 border-surface-600',
};

const cultureMap: Record<string, string> = {
  '字节风': 'ByteDance',
  '阿里风': 'Alibaba',
  '创业风': 'Startup',
  '其他': 'Other',
  '互联网大厂': 'Big Tech',
  '外企': 'MNC',
  '传统企业': 'Traditional',
};

const personalityMap: Record<string, string> = {
  '严谨': 'Rigorous',
  '直接': 'Direct',
  '完美主义': 'Perfectionist',
  '务实': 'Pragmatic',
  '细心': 'Meticulous',
  '坦诚': 'Candid',
  '经验丰富': 'Seasoned',
  '不废话': 'No BS',
  '现实主义': 'Realist',
  '黑色幽默': 'Dark Humor',
  '直击要害': 'Straight Shooter',
  '去魅思维': 'Demystifier',
  '直接压迫': 'Bluntly Direct',
  '人文关怀': 'Humanist',
  '理性克制': 'Rational',
  '举例达人': 'Example Pro',
};
---

<a
  href={`${base}/gallery/${skill.slug}/`}
  class="card-base card-hover p-5 flex flex-col gap-4 group cursor-pointer block relative"
>
  {skill.pinned && (
    <span class="absolute top-3 right-3 text-xs font-mono px-2 py-0.5 rounded bg-brand-500/15 border border-brand-500/30 text-brand-400">
      <span class="lang-zh">置顶</span>
      <span class="lang-en">pinned</span>
    </span>
  )}
  {isNew && !skill.pinned && (
    <span class="absolute top-3 right-3 text-xs font-mono px-2 py-0.5 rounded bg-green-500/15 border border-green-500/30 text-green-400">
      NEW
    </span>
  )}
  <!-- Header -->
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/30 to-purple-500/20 border border-brand-500/30 flex items-center justify-center shrink-0 text-base font-bold text-brand-300">
        {skill.name.charAt(0)}
      </div>
      <div class="min-w-0">
        <h3 class="font-bold text-white text-base group-hover:text-brand-400 transition-colors truncate">
          {skill.name}
        </h3>
        {skill.level && (
          <p class="text-surface-500 text-base truncate">
            <span class="lang-zh">{skill.level}</span>
            <span class="lang-en">{skill.level_en || skill.level}</span>
          </p>
        )}
      </div>
    </div>

    <div class="flex items-center gap-1.5 shrink-0">
      {skill.type === 'meta-skill' && (
        <span class="text-base px-2 py-0.5 rounded bg-purple-500/15 border border-purple-500/30 text-purple-300 font-mono">
          meta-skill
        </span>
      )}
      {skill.company_culture && (
        <span class="text-base px-2 py-0.5 rounded bg-surface-700/50 border border-surface-600/50 text-surface-400 font-mono">
          <span class="lang-zh">{skill.company_culture}</span>
          <span class="lang-en">{cultureMap[skill.company_culture] || skill.company_culture}</span>
        </span>
      )}
    </div>
  </div>

  <!-- Description -->
  <p class="text-surface-400 text-base leading-relaxed line-clamp-2">
    <span class="lang-zh">{skill.description}</span>
    <span class="lang-en">{skill.description_en || skill.description}</span>
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mt-auto">
    {skill.tags?.slice(0, 3).map((tag) => (
      <span class={`inline-flex items-center px-2 py-0.5 rounded text-base border font-mono ${tagColors[tag] || tagColors.other}`}>
        {tag}
      </span>
    ))}
    {skill.personality?.slice(0, 2).map((p) => (
      <span class="tag-pill">
        <span class="lang-zh">{p}</span>
        <span class="lang-en">{personalityMap[p] || p}</span>
      </span>
    ))}
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between pt-2 border-t border-surface-700/50">
    <div class="flex items-center gap-1.5">
      <img
        src={`https://github.com/${skill.author.github}.png?size=24`}
        alt={skill.author.name}
        class="w-5 h-5 rounded-full border border-surface-600"
        loading="lazy"
        onerror="this.style.display='none'"
      />
      <span class="text-surface-500 text-base">{skill.author.name}</span>
    </div>
    <div class="flex items-center gap-2.5">
      {typeof skill.stars === 'number' && (
        <span
          class="flex items-center gap-1 text-surface-500 text-base font-mono"
          title={skill.stars_synced_at ? `GitHub stars · synced ${skill.stars_synced_at.slice(0, 10)}` : 'GitHub stars'}
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
          </svg>
          {formatStars(skill.stars)}
        </span>
      )}
      <span class="text-surface-600 text-base font-mono">{skill.created_at}</span>
    </div>
  </div>
</a>
