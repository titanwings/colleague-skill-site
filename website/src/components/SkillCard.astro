---
import type { SkillMeta } from '../types/skill';

interface Props {
  skill: SkillMeta;
  base: string;
}

const { skill, base } = Astro.props;

const tagColors: Record<string, string> = {
  security: 'bg-red-500/10 text-red-400 border-red-500/20',
  backend: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  frontend: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  devops: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  data: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  design: 'bg-pink-500/10 text-pink-400 border-pink-500/20',
  product: 'bg-green-500/10 text-green-400 border-green-500/20',
  hr: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  management: 'bg-brand-500/10 text-brand-400 border-brand-500/20',
  other: 'bg-surface-700 text-surface-400 border-surface-600',
};

const preview = skill.preview_conversation?.[0];
const skillPreview = skill.preview_conversation?.[1];
---

<a
  href={`${base}/gallery/${skill.slug}/`}
  class="card-base card-hover p-5 flex flex-col gap-4 group cursor-pointer block"
>
  <!-- Header -->
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <!-- Avatar placeholder based on name -->
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/30 to-purple-500/20 border border-brand-500/30 flex items-center justify-center shrink-0 text-base font-bold text-brand-300">
        {skill.name.charAt(0)}
      </div>
      <div class="min-w-0">
        <h3 class="font-bold text-white text-sm group-hover:text-brand-400 transition-colors truncate">
          {skill.name}
        </h3>
        {skill.level && (
          <p class="text-surface-500 text-xs truncate">{skill.level}</p>
        )}
      </div>
    </div>

    {skill.company_culture && (
      <span class="shrink-0 text-xs px-2 py-0.5 rounded bg-surface-700/50 border border-surface-600/50 text-surface-400 font-mono">
        {skill.company_culture}
      </span>
    )}
  </div>

  <!-- Description -->
  <p class="text-surface-400 text-xs leading-relaxed line-clamp-2">
    {skill.description}
  </p>

  <!-- Preview conversation snippet -->
  {preview && skillPreview && (
    <div class="bg-surface-900/60 rounded-lg p-3 space-y-2 border border-surface-700/50 text-xs">
      <div class="flex gap-2">
        <span class="text-surface-500 shrink-0">你：</span>
        <span class="text-surface-400 line-clamp-1">{preview.content}</span>
      </div>
      <div class="flex gap-2">
        <span class="text-brand-500 shrink-0 font-semibold">TA：</span>
        <span class="text-surface-300 line-clamp-2">{skillPreview.content}</span>
      </div>
    </div>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mt-auto">
    {skill.tags?.slice(0, 3).map((tag) => (
      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs border font-mono ${tagColors[tag] || tagColors.other}`}>
        {tag}
      </span>
    ))}
    {skill.personality?.slice(0, 2).map((p) => (
      <span class="tag-pill">{p}</span>
    ))}
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between pt-2 border-t border-surface-700/50">
    <div class="flex items-center gap-1.5">
      <img
        src={`https://github.com/${skill.author.github}.png?size=24`}
        alt={skill.author.name}
        class="w-5 h-5 rounded-full border border-surface-600"
        loading="lazy"
        onerror="this.style.display='none'"
      />
      <span class="text-surface-500 text-xs">{skill.author.name}</span>
    </div>
    <span class="text-surface-600 text-xs font-mono">{skill.created_at}</span>
  </div>
</a>
