---
import SkillCard from './SkillCard.astro';
import type { SkillMeta } from '../types/skill';

interface Props {
  skills: SkillMeta[];
  base: string;
}

const { skills, base } = Astro.props;

const allTags = [...new Set(skills.flatMap((s) => s.tags || []))].sort();
const allCultures = [...new Set(skills.map((s) => s.company_culture).filter(Boolean))];
---

<div>
  <!-- Filter bar -->
  <div class="flex flex-col sm:flex-row gap-4 mb-8" id="filter-bar">
    <div class="relative flex-1">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        type="text"
        id="search-input"
        data-placeholder-zh="搜索 Skill 名称、描述、标签..."
        data-placeholder-en="Search skills by name, description, tag..."
        placeholder="搜索 Skill 名称、描述、标签..."
        class="w-full pl-10 pr-4 py-2.5 bg-surface-800 border border-surface-700 hover:border-surface-600 focus:border-brand-500/60 focus:outline-none rounded-lg text-sm text-white placeholder-surface-500 transition-colors"
      />
    </div>
    <div class="flex gap-2 flex-wrap">
      <select
        id="tag-filter"
        class="px-3 py-2.5 bg-surface-800 border border-surface-700 hover:border-surface-600 focus:border-brand-500/60 focus:outline-none rounded-lg text-sm text-surface-300 transition-colors cursor-pointer"
      >
        <option value="" data-zh="全部领域" data-en="All Domains">全部领域</option>
        {allTags.map((tag) => (
          <option value={tag}>{tag}</option>
        ))}
      </select>
      <select
        id="culture-filter"
        class="px-3 py-2.5 bg-surface-800 border border-surface-700 hover:border-surface-600 focus:border-brand-500/60 focus:outline-none rounded-lg text-sm text-surface-300 transition-colors cursor-pointer"
      >
        <option value="" data-zh="全部风格" data-en="All Styles">全部风格</option>
        {allCultures.map((c) => (
          <option value={c}>{c}</option>
        ))}
      </select>
    </div>
  </div>

  <!-- Results count -->
  <p class="text-surface-500 text-sm mb-6" id="results-count">
    <span class="lang-zh">共 <span id="count-num" class="text-surface-300 font-medium">{skills.length}</span> 个 Skill</span>
    <span class="lang-en"><span id="count-num-en" class="text-surface-300 font-medium">{skills.length}</span> Skills</span>
  </p>

  <!-- Grid -->
  <div
    id="skills-grid"
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
    data-skills={JSON.stringify(skills)}
    data-base={base}
  >
    {skills.map((skill) => (
      <div
        class="skill-item"
        data-name={skill.name.toLowerCase()}
        data-description={skill.description.toLowerCase()}
        data-tags={skill.tags?.join(' ').toLowerCase()}
        data-personality={skill.personality?.join(' ')}
        data-culture={skill.company_culture}
      >
        <SkillCard skill={skill} base={base} />
      </div>
    ))}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden text-center py-20">
    <div class="text-5xl mb-4">🔍</div>
    <p class="text-surface-400 text-lg font-medium mb-2">
      <span class="lang-zh">没找到匹配的 Skill</span>
      <span class="lang-en">No matching Skills found</span>
    </p>
    <p class="text-surface-600 text-sm">
      <span class="lang-zh">换个关键词试试，或者<a href="https://github.com/titanwings/colleague-skill-site/issues/new?template=submit-skill.yml" class="text-brand-400 hover:underline" target="_blank" rel="noopener noreferrer">提交一个新的</a></span>
      <span class="lang-en">Try a different keyword, or <a href="https://github.com/titanwings/colleague-skill-site/issues/new?template=submit-skill.yml" class="text-brand-400 hover:underline" target="_blank" rel="noopener noreferrer">submit a new one</a></span>
    </p>
  </div>
</div>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement;
  const cultureFilter = document.getElementById('culture-filter') as HTMLSelectElement;
  const skillItems = document.querySelectorAll<HTMLElement>('.skill-item');
  const countNum = document.getElementById('count-num');
  const countNumEn = document.getElementById('count-num-en');
  const emptyState = document.getElementById('empty-state');
  const skillsGrid = document.getElementById('skills-grid');

  function updateLangUI() {
    const isEn = document.documentElement.getAttribute('data-lang') === 'en';
    // Update search placeholder
    if (searchInput) {
      searchInput.placeholder = isEn
        ? searchInput.dataset.placeholderEn || ''
        : searchInput.dataset.placeholderZh || '';
    }
    // Update select first options
    const tagFirst = tagFilter?.querySelector('option[data-zh]') as HTMLOptionElement;
    const cultureFirst = cultureFilter?.querySelector('option[data-zh]') as HTMLOptionElement;
    if (tagFirst) tagFirst.text = isEn ? (tagFirst.dataset.en || '') : (tagFirst.dataset.zh || '');
    if (cultureFirst) cultureFirst.text = isEn ? (cultureFirst.dataset.en || '') : (cultureFirst.dataset.zh || '');
  }

  // Run on load
  updateLangUI();

  // Watch for lang changes
  const observer = new MutationObserver(updateLangUI);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

  function filterSkills() {
    const query = searchInput?.value.toLowerCase().trim() || '';
    const tag = tagFilter?.value.toLowerCase() || '';
    const culture = cultureFilter?.value || '';

    let visibleCount = 0;

    skillItems.forEach((item) => {
      const name = item.dataset.name || '';
      const desc = item.dataset.description || '';
      const tags = item.dataset.tags || '';
      const personality = item.dataset.personality || '';
      const itemCulture = item.dataset.culture || '';

      const matchesQuery = !query || name.includes(query) || desc.includes(query) || tags.includes(query) || personality.toLowerCase().includes(query);
      const matchesTag = !tag || tags.includes(tag);
      const matchesCulture = !culture || itemCulture === culture;

      const visible = matchesQuery && matchesTag && matchesCulture;
      item.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    if (countNum) countNum.textContent = String(visibleCount);
    if (countNumEn) countNumEn.textContent = String(visibleCount);
    if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
    if (skillsGrid) skillsGrid.classList.toggle('hidden', visibleCount === 0);
  }

  searchInput?.addEventListener('input', filterSkills);
  tagFilter?.addEventListener('change', filterSkills);
  cultureFilter?.addEventListener('change', filterSkills);
</script>
