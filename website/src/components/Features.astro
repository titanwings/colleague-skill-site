---
const features = [
  {
    icon: '🧬',
    title: '蒸馏，不是复制',
    subtitle: 'Distillation, Not Imitation',
    description: '不是把聊天记录喂给 GPT 让它背台词。而是提炼决策逻辑、工作方式、说话风格，让 Skill 真正"像那个人"。',
    tags: ['Work Skill', 'Persona', '5层性格'],
    color: 'from-purple-500/20 to-blue-500/10',
    borderColor: 'border-purple-500/20',
    tagColor: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  },
  {
    icon: '🔥',
    title: '原材料随便扔',
    subtitle: 'Any Source, Any Format',
    description: '飞书 / 钉钉 / Slack / 邮件 / GitHub PR / 截图 / PDF……能导出的全塞进来，边角料也算，多多益善。',
    tags: ['Feishu API', 'DingTalk', 'Slack', '.eml'],
    color: 'from-orange-500/20 to-red-500/10',
    borderColor: 'border-orange-500/20',
    tagColor: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  },
  {
    icon: '📈',
    title: '越用越像本人',
    subtitle: 'Gets Better Over Time',
    description: '用着用着发现不对？直接说"他不会这样做，应该是……"——Skill 当场记住，下次改正。比真人还好管。',
    tags: ['对话纠正', '增量更新', '版本回滚'],
    color: 'from-green-500/20 to-teal-500/10',
    borderColor: 'border-green-500/20',
    tagColor: 'bg-green-500/10 text-green-400 border-green-500/20',
  },
  {
    icon: '🌍',
    title: '开放，不锁厂商',
    subtitle: 'Open Standard, No Lock-in',
    description: 'AgentSkills 开放标准，Claude Code / OpenClaw / 任何 MCP 客户端都能用。Skill 是你的，平台随你换。',
    tags: ['AgentSkills', 'MCP', 'Claude Code', 'OpenClaw'],
    color: 'from-brand-500/20 to-yellow-500/10',
    borderColor: 'border-brand-500/20',
    tagColor: 'bg-brand-500/10 text-brand-400 border-brand-500/20',
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-surface-800/30"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-800 border border-surface-700 rounded-full text-xs text-surface-400 font-mono mb-4">
        WHY .SKILL
      </div>
      <h2 class="section-heading">
        不只是 Prompt，<span class="gradient-text">是真正的数字分身</span>
      </h2>
      <p class="section-sub">
        那些你再也问不到的人——其实还没走远
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children">
      {features.map((f) => (
        <div class={`card-base card-hover p-6 bg-gradient-to-br ${f.color} ${f.borderColor} cursor-default`}>
          <div class="flex items-start gap-4">
            <div class="text-3xl shrink-0 mt-0.5">{f.icon}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-2 mb-1">
                <h3 class="text-lg font-bold text-white">{f.title}</h3>
                <span class="text-xs text-surface-500 font-mono">{f.subtitle}</span>
              </div>
              <p class="text-surface-400 text-sm leading-relaxed mb-4">{f.description}</p>
              <div class="flex flex-wrap gap-2">
                {f.tags.map((tag) => (
                  <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-mono border ${f.tagColor}`}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
