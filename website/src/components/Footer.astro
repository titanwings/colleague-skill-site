---
const base = import.meta.env.BASE_URL;

const links = {
  '项目': [
    { label: '快速开始', href: 'https://github.com/titanwings/colleague-skill#readme', external: true },
    { label: 'PRD 文档', href: 'https://github.com/titanwings/colleague-skill/blob/main/docs/PRD.md', external: true },
    { label: 'Changelog', href: 'https://github.com/titanwings/colleague-skill/releases', external: true },
  ],
  '社区': [
    { label: 'Skill Gallery', href: `${base}/gallery/`, external: false },
    { label: '提交 Skill', href: 'https://github.com/titanwings/colleague-skill/issues/new?template=submit-skill.yml', external: true },
    { label: 'GitHub Discussions', href: 'https://github.com/titanwings/colleague-skill/discussions', external: true },
  ],
  '标准': [
    { label: 'AgentSkills Spec', href: 'https://github.com/agentskills/spec', external: true },
    { label: 'MCP Protocol', href: 'https://modelcontextprotocol.io', external: true },
    { label: 'Claude Code', href: 'https://claude.ai/code', external: true },
  ],
};
---

<footer class="border-t border-surface-800 bg-surface-900/50 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-brand-500/20 border border-brand-500/40 flex items-center justify-center">
            <span class="text-brand-400 font-mono font-bold text-sm">cs</span>
          </div>
          <span class="font-bold text-white text-sm">
            colleague<span class="text-brand-400">-skill</span>
          </span>
        </a>
        <p class="text-surface-500 text-sm leading-relaxed mb-4">
          把同事蒸馏成 AI Skill。<br/>
          遵循 AgentSkills 开放标准。
        </p>
        <div class="flex items-center gap-3">
          <a
            href="https://github.com/titanwings/colleague-skill"
            target="_blank"
            rel="noopener noreferrer"
            class="text-surface-500 hover:text-white transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <h4 class="text-xs font-semibold text-surface-400 uppercase tracking-wider mb-3">{group}</h4>
          <ul class="space-y-2">
            {items.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener noreferrer' : undefined}
                  class="text-surface-500 hover:text-surface-200 text-sm transition-colors inline-flex items-center gap-1"
                >
                  {item.label}
                  {item.external && (
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-8 border-t border-surface-800">
      <p class="text-surface-600 text-xs">
        MIT License · Made with ❤️ by
        <a href="https://github.com/titanwings" class="text-surface-500 hover:text-brand-400 transition-colors" target="_blank" rel="noopener noreferrer">titanwings</a>
      </p>
      <p class="text-surface-700 text-xs font-mono">
        // 同事不在了，但 Skill 还在
      </p>
    </div>
  </div>
</footer>
