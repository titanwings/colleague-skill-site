---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllSkills, getSkillBySlug } from '../../lib/skills';
import type { SkillMeta } from '../../types/skill';

export async function getStaticPaths() {
  const skills = await getAllSkills();
  return skills.map((skill) => ({
    params: { slug: skill.slug },
    props: { skill },
  }));
}

interface Props {
  skill: SkillMeta;
}

const { skill } = Astro.props;
const base = import.meta.env.BASE_URL;

const cultureMap: Record<string, string> = {
  '字节风': 'ByteDance',
  '阿里风': 'Alibaba',
  '创业风': 'Startup',
  '其他': 'Other',
  '互联网大厂': 'Big Tech',
  '外企': 'MNC',
  '传统企业': 'Traditional',
};

const personalityMap: Record<string, string> = {
  '严谨': 'Rigorous',
  '直接': 'Direct',
  '完美主义': 'Perfectionist',
  '务实': 'Pragmatic',
  '细心': 'Meticulous',
  '坦诚': 'Candid',
  '经验丰富': 'Seasoned',
  '不废话': 'No BS',
  '现实主义': 'Realist',
  '黑色幽默': 'Dark Humor',
  '直击要害': 'Straight Shooter',
  '去魅思维': 'Demystifier',
  '直接压迫': 'Bluntly Direct',
  '人文关怀': 'Humanist',
  '理性克制': 'Rational',
  '举例达人': 'Example Pro',
};

const tagColors: Record<string, string> = {
  security: 'bg-red-500/10 text-red-400 border-red-500/20',
  backend: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  frontend: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  devops: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  data: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  design: 'bg-pink-500/10 text-pink-400 border-pink-500/20',
  product: 'bg-green-500/10 text-green-400 border-green-500/20',
  hr: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  management: 'bg-brand-500/10 text-brand-400 border-brand-500/20',
  other: 'bg-surface-700 text-surface-400 border-surface-600',
};
---

<BaseLayout
  title={`${skill.name} — colleague-skill Gallery`}
  description={skill.description}
  ogType="profile"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20">

    <!-- Back link -->
    <a
      href={`${base}/gallery/`}
      class="inline-flex items-center gap-2 text-surface-500 hover:text-brand-400 text-sm mb-8 transition-colors group"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <span class="lang-zh">返回 Gallery</span>
      <span class="lang-en">Back to Gallery</span>
    </a>

    <!-- Header card -->
    <div class="card-base p-8 mb-6">
      <div class="flex flex-col sm:flex-row gap-6">
        <!-- Avatar -->
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-500/30 to-purple-500/20 border border-brand-500/30 flex items-center justify-center text-2xl font-black text-brand-300 shrink-0">
          {skill.name.charAt(0)}
        </div>

        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-start gap-3 mb-2">
            <h1 class="text-2xl font-black text-white">{skill.name}</h1>
            {skill.company_culture && (
              <span class="px-2.5 py-0.5 text-sm rounded bg-surface-700 border border-surface-600 text-surface-300 font-mono">
                <span class="lang-zh">{skill.company_culture}</span>
                <span class="lang-en">{cultureMap[skill.company_culture] || skill.company_culture}</span>
              </span>
            )}
          </div>
          {skill.level && (
            <p class="text-surface-500 text-sm mb-3 font-mono">
              <span class="lang-zh">{skill.level}</span>
              <span class="lang-en">{skill.level_en || skill.level}</span>
            </p>
          )}
          <p class="text-surface-300 leading-relaxed">
            <span class="lang-zh">{skill.description}</span>
            <span class="lang-en">{skill.description_en || skill.description}</span>
          </p>
        </div>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-6 pt-6 border-t border-surface-700">
        {skill.tags?.map((tag) => (
          <span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-mono border ${tagColors[tag] || tagColors.other}`}>
            {tag}
          </span>
        ))}
        {skill.personality?.map((p) => (
          <span class="tag-pill text-sm">
            <span class="lang-zh">{p}</span>
            <span class="lang-en">{personalityMap[p] || p}</span>
          </span>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Left: How to use -->
      <div class="md:col-span-2 space-y-6">
        <!-- How to use -->
        <div class="card-base p-6">
          <h2 class="text-sm font-semibold text-surface-400 uppercase tracking-wider mb-5 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            <span class="lang-zh">如何使用这个 Skill</span>
            <span class="lang-en">How to Use This Skill</span>
          </h2>
          <div class="space-y-4 text-sm text-surface-400">
            <p>
              <span class="lang-zh">首先确保你已经安装了 colleague-skill 并配置好了对应的 Skill 文件。</span>
              <span class="lang-en">Make sure you have colleague-skill installed and the Skill file configured.</span>
            </p>

            <div class="space-y-3">
              <p class="text-surface-300 font-medium">
                <span class="lang-zh">在 Claude Code 中召唤：</span>
                <span class="lang-en">Summon in Claude Code:</span>
              </p>
              <div class="code-block p-3">
                <pre class="text-sm text-brand-300 font-mono">
                  <span class="lang-zh">/{skill.slug} 你的问题</span>
                  <span class="lang-en">/{skill.slug} your question</span>
                </pre>
              </div>
            </div>

            {skill.skill_repo && (
              <div class="flex items-start gap-3 p-3 bg-brand-500/5 border border-brand-500/20 rounded-lg">
                <svg class="w-4 h-4 text-brand-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <p class="text-brand-400 text-sm font-medium mb-1">
                    <span class="lang-zh">作者提供了 Skill 文件</span>
                    <span class="lang-en">Author provided a Skill file</span>
                  </p>
                  <a
                    href={skill.skill_repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-surface-400 hover:text-brand-400 transition-colors inline-flex items-center gap-1"
                  >
                    {skill.skill_repo}
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                  </a>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Right: Meta info -->
      <div class="space-y-4">
        <!-- Author card -->
        <div class="card-base p-5">
          <h3 class="text-sm font-semibold text-surface-500 uppercase tracking-wider mb-4">
            <span class="lang-zh">贡献者</span>
            <span class="lang-en">Contributor</span>
          </h3>
          <div class="flex items-center gap-3">
            <img
              src={`https://github.com/${skill.author.github}.png?size=48`}
              alt={skill.author.name}
              class="w-10 h-10 rounded-full border border-surface-600"
              loading="lazy"
              onerror="this.style.display='none'"
            />
            <div>
              <p class="text-white text-sm font-medium">{skill.author.name}</p>
              <a
                href={`https://github.com/${skill.author.github}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-surface-500 hover:text-brand-400 transition-colors flex items-center gap-1"
              >
                @{skill.author.github}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Meta card -->
        <div class="card-base p-5 space-y-3">
          <h3 class="text-sm font-semibold text-surface-500 uppercase tracking-wider">
            <span class="lang-zh">元信息</span>
            <span class="lang-en">Meta</span>
          </h3>
          {[
            { labelZh: '创建时间', labelEn: 'Created', valueZh: skill.created_at, valueEn: skill.created_at },
            { labelZh: '职级', labelEn: 'Level', valueZh: skill.level || '-', valueEn: skill.level_en || skill.level || '-' },
            { labelZh: '企业文化', labelEn: 'Culture', valueZh: skill.company_culture || '-', valueEn: (skill.company_culture ? (cultureMap[skill.company_culture] || skill.company_culture) : '-') },
          ].map((item) => (
            <div class="flex justify-between items-center text-sm">
              <span class="text-surface-500">
                <span class="lang-zh">{item.labelZh}</span>
                <span class="lang-en">{item.labelEn}</span>
              </span>
              <span class="text-surface-300 font-mono text-sm">
                <span class="lang-zh">{item.valueZh}</span>
                <span class="lang-en">{item.valueEn}</span>
              </span>
            </div>
          ))}
        </div>

        <!-- Share / also like -->
        <div class="card-base p-5">
          <h3 class="text-sm font-semibold text-surface-500 uppercase tracking-wider mb-3">
            <span class="lang-zh">想要这个 dot-skill？</span>
            <span class="lang-en">Want This dot-skill?</span>
          </h3>
          <p class="text-surface-500 text-sm mb-4">
            <span class="lang-zh">用 colleague-skill 生成属于你自己版本的同类 Skill</span>
            <span class="lang-en">Use colleague-skill to distill your own version</span>
          </p>
          <a
            href="https://github.com/titanwings/colleague-skill#readme"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full justify-center text-sm py-2.5"
          >
            <span class="lang-zh">开始蒸馏 →</span>
            <span class="lang-en">Start Distilling →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
